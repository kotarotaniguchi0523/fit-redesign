{
	"$schema": "https://unpkg.com/knip@5/schema.json",
	"entry": ["src/pages/**/*.astro", "src/scripts/*.ts"],
	"project": ["src/**/*.{ts,tsx,astro}"],
	"ignore": [],
	"ignoreDependencies": ["tailwindcss", "@vitest/coverage-v8"],
	"ignoreExportsUsedInFile": true,
	"rules": {
		"exports": "warn",
		"types": "warn"
	}
}
