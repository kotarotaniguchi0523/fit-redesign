{
	"$schema": "https://unpkg.com/knip@5/schema.json",
	"entry": [
		"src/pages/**/*.astro",
		"src/app.ts",
		"src/features/study/studyHome.ts",
		"src/features/dashboard/dashboard.ts"
	],
	"project": [
		"src/**/*.{ts,tsx,astro}"
	],
	"ignore": [
		"src/constants.ts",
		"src/types/answer.ts"
	],
	"ignoreDependencies": [
		"tailwindcss",
		"cloudflare",
		"workerd"
	],
	"ignoreExportsUsedInFile": true,
	"rules": {
		"exports": "warn",
		"types": "warn"
	}
}