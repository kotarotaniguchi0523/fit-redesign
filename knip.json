{
	"$schema": "https://unpkg.com/knip@5/schema.json",
	"entry": [
		"app/server.ts",
		"app/client.ts",
		"app/routes/**/*.{ts,tsx}",
		"app/api.ts"
	],
	"project": [
		"app/**/*.{ts,tsx}",
		"src/**/*.{ts,tsx}"
	],
	"ignore": [
		"src/constants.ts",
		"src/types/answer.ts"
	],
	"ignoreDependencies": [
		"tailwindcss",
		"cloudflare",
		"workerd"
	],
	"ignoreExportsUsedInFile": true,
	"rules": {
		"exports": "warn",
		"types": "warn"
	}
}
