{
	"name": "fit-redesign",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"packageManager": "pnpm@11.5.0",
	"scripts": {
		"dev": "astro dev",
		"build": "astro build",
		"preview": "astro preview",
		"format": "biome format --write .",
		"check": "biome ci .",
		"typecheck": "tsgo --noEmit",
		"typecheck:full": "astro check && tsgo --noEmit",
		"knip": "knip",
		"add-year": "node scripts/add-year.mjs",
		"apply-year-mapping": "node scripts/apply-year-mapping.mjs",
		"figure-gen": "node scripts/generate-figure.mjs",
		"data:convert": "node scripts/convert-exams-to-json.mjs",
		"db:migrate:local": "wrangler d1 migrations apply fit-timer-db --local",
		"db:query:local": "wrangler d1 execute fit-timer-db --local --command",
		"test": "vitest",
		"test:run": "vitest run",
		"test:coverage": "vitest run --coverage"
	},
	"devDependencies": {
		"@astrojs/check": "^0.9.9",
		"@biomejs/biome": "^2.4.16",
		"@cloudflare/workers-types": "^4.20260601.1",
		"@tailwindcss/vite": "^4.3.0",
		"@typescript/native-preview": "7.0.0-dev.20260527.2",
		"@vitest/coverage-v8": "^4.1.8",
		"jsdom": "^29.1.1",
		"knip": "^6.15.0",
		"tailwindcss": "^4.3.0",
		"vitest": "^4.1.8",
		"workerd": "^1.20260601.1",
		"wrangler": "^4.95.0"
	},
	"dependencies": {
		"@astrojs/cloudflare": "^13.6.0",
		"@astrojs/sitemap": "^3.7.3",
		"@hono/zod-validator": "^0.8.0",
		"astro": "6.4.2",
		"chart.js": "^4.5.1",
		"hono": "^4.12.23",
		"zod": "^4.4.3"
	}
}
