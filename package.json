{
	"name": "fit-redesign",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"packageManager": "pnpm@11.5.0",
	"scripts": {
		"dev": "vite",
		"build": "vite build --mode client && vite build",
		"preview": "wrangler dev",
		"format": "biome format --write .",
		"check": "biome ci .",
		"typecheck": "tsgo --noEmit",
		"typecheck:full": "tsgo --noEmit",
		"knip": "knip",
		"db:migrate:local": "wrangler d1 migrations apply fit-timer-db --local",
		"db:query:local": "wrangler d1 execute fit-timer-db --local --command",
		"test": "vitest",
		"test:run": "vitest run",
		"test:coverage": "vitest run --coverage",
		"deploy": "wrangler deploy"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.16",
		"@cloudflare/workers-types": "^4.20260607.1",
		"@hono/cli": "^0.1.10",
		"@hono/vite-build": "^1.11.1",
		"@hono/vite-dev-server": "^0.26.0",
		"@mdx-js/rollup": "^3.1.1",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.3.0",
		"@types/better-sqlite3": "^7.6.13",
		"@typescript/native-preview": "7.0.0-dev.20260527.2",
		"@vitest/coverage-v8": "^4.1.8",
		"better-sqlite3": "^12.10.0",
		"jsdom": "^29.1.1",
		"knip": "^6.16.1",
		"remark-gfm": "^4.0.1",
		"tailwindcss": "^4.3.0",
		"vite": "^7.3.5",
		"vitest": "^4.1.8",
		"workerd": "^1.20260607.1",
		"wrangler": "^4.98.0"
	},
	"dependencies": {
		"@hono/zod-validator": "^0.8.0",
		"chart.js": "^4.5.1",
		"drizzle-orm": "1.0.0-beta.22",
		"hono": "^4.12.23",
		"honox": "^0.1.56",
		"zod": "^4.4.3"
	}
}
