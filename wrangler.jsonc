{
	"name": "fit-redesign",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"compatibility_date": "2025-01-01",
	"compatibility_flags": ["nodejs_compat"],
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "fit-timer-db",
			"database_id": "57532062-e9cf-4a86-a89f-fc6fdb1e3ba5"
		}
	]
}
