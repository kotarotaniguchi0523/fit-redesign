---
import { type TableFigureData, buildTableConfig } from "../../lib/figures/table-renderer";

interface Props {
	figureData: TableFigureData;
}

const { figureData } = Astro.props;

const config = buildTableConfig(figureData);
---

<div class="w-full overflow-x-auto">
  <table
    aria-label={config.ariaLabel}
    class="max-w-2xl min-w-max border-2 border-gray-800 border-collapse"
  >
    <thead>
      <tr>
        {config.columns.map((column) => (
          <th class="border border-gray-800 bg-gray-100 text-black font-bold text-center px-3 py-2">
            {column.label}
          </th>
        ))}
      </tr>
    </thead>
    <tbody>
      {config.rows.map((row) => (
        <tr>
          {config.columns.map((column) => (
            <td class="border border-gray-800 text-black font-mono text-center px-3 py-2">
              {String(row[column.key])}
            </td>
          ))}
        </tr>
      ))}
    </tbody>
  </table>
</div>
