---
import type { Question } from "../types/index";
import { overlineToHtml } from "../utils/overline";
import { questionToMarkdown } from "../utils/questionToMarkdown";
import BinaryTree from "./figures/BinaryTree.astro";
import Flowchart from "./figures/Flowchart.astro";
import LogicCircuit from "./figures/LogicCircuit.astro";
import ParityCheck from "./figures/ParityCheck.astro";
import StateDiagram from "./figures/StateDiagram.astro";
import TableRenderer from "./figures/TableRenderer.astro";
import TruthTable from "./figures/TruthTable.astro";

interface Props {
	question: Question;
}

const { question } = Astro.props;
const markdownText = questionToMarkdown(question);
const hasOptions = !!question.options && question.options.length > 0;
---

<article data-question-card data-question-id={question.id} class="q-card">
	{/* 進捗チップ（回答後にJSが表示） */}
	<div data-status-chip hidden class="q-chip"></div>

	<div class="q-card__body">
		{/* 1. 問題番号 + 種別 */}
		<header class="q-head">
			<span class="q-num">{question.number}</span>
			<div>
				<p class="q-eyebrow">問題 {question.number}</p>
				<p class="q-hint">
					{hasOptions ? "選択肢を1つ選んで確かめよう" : "答えを出してから、答え合わせしよう"}
				</p>
			</div>
		</header>

		{/* 2. 問題文 */}
		<div class="q-text-wrap">
			<p class="q-text" set:html={overlineToHtml(question.text)}></p>
		</div>

		{/* 3. 図表 */}
		{
			question.figureData && (
				<div class="q-figure-wrap">
					{question.figureData.type === "stateDiagram" && (
						<StateDiagram
							nodes={question.figureData.nodes}
							transitions={question.figureData.transitions}
						/>
					)}
					{question.figureData.type === "binaryTree" && (
						<BinaryTree
							root={question.figureData.root}
							width={question.figureData.width}
							height={question.figureData.height}
						/>
					)}
					{question.figureData.type === "truthTable" && (
						<TruthTable
							columns={question.figureData.columns}
							rows={question.figureData.rows}
						/>
					)}
					{question.figureData.type === "parityCheck" && (
						<ParityCheck data={question.figureData.data} />
					)}
					{question.figureData.type === "logicCircuit" && (
						<LogicCircuit
							inputs={question.figureData.inputs}
							outputs={question.figureData.outputs}
							gates={question.figureData.gates}
							wires={question.figureData.wires}
						/>
					)}
					{question.figureData.type === "flowchart" && (
						<Flowchart
							nodes={question.figureData.nodes}
							edges={question.figureData.edges}
							width={question.figureData.width}
							height={question.figureData.height}
						/>
					)}
					{(question.figureData.type === "dataTable" ||
						question.figureData.type === "huffmanTable" ||
						question.figureData.type === "linkedListTable" ||
						question.figureData.type === "normalDistributionTable") && (
						<TableRenderer figureData={question.figureData as any} />
					)}
				</div>
			)
		}

		{
			!question.figureData && question.figureDescription && (
				<div class="q-figure-fallback">
					<strong>図:</strong> <span set:html={overlineToHtml(question.figureDescription)} />
				</div>
			)
		}

		{/* 4. 回答（選択式 or 記述式の自己採点） */}
		{
			hasOptions ? (
				<div
					class="q-options"
					data-answer-selector
					data-question-id={question.id}
					data-correct-label={question.answer}
				>
					{question.options?.map((option) => (
						<div data-option class="q-option">
							<span class="q-option__label">{option.label}</span>
							<span
								class="q-option__value"
								set:html={overlineToHtml(option.value || "(選択肢未入力)")}
							/>
						</div>
					))}
				</div>
			) : (
				<div class="mt-4 block" data-self-grade data-question-id={question.id} />

			)
		}

		{/* 5. 解き方パネル（回答後にJSが表示） */}
		<div data-solution hidden class="q-solution">
			<p class="q-solution__title">解き方</p>
			<div class="q-solution__answer">
				<span class="q-solution__answer-label">答え</span>
				<span class="q-solution__answer-value" set:html={overlineToHtml(question.answer)} />
			</div>
			{
				question.explanation && (
					<p class="q-solution__explanation" set:html={overlineToHtml(question.explanation)} />
				)
			}
		</div>

		{/* 6. ツール（控えめなフッター） */}
		<footer class="q-footer">
			<div data-question-timer data-question-id={question.id}></div>
			<button
				data-copy-button
				data-copy-text={markdownText}
				class="q-tool"
				aria-label="Markdownでコピー"
				title="Markdownでコピー"
			>
				<svg class="copy-icon h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
					<path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
				</svg>
				<svg class="check-icon hidden h-4 w-4 text-green-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<polyline points="20 6 9 17 4 12"></polyline>
				</svg>
			</button>
		</footer>
	</div>
</article>
