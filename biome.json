{
	"$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
	"files": {
		"includes": [
			"app/**",
			"docs/**",
			"!!**/.claude",
			"!!**/.serena",
			"!!**/node_modules",
			"!!**/.git",
			"!!**/.vscode",
			"!!**/.idea",
			"!!**/screenshots",
			"!!**/dist",
			"!!**/dist-ssr"
		]
	},
	"assist": {
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"complexity": {
				"noForEach": "error",
				"noUselessFragments": "error",
				"useOptionalChain": "error",
				"useFlatMap": "error",
				"useSimplifiedLogicExpression": "error",
				"noVoid": "error",
				"noUselessStringConcat": "error",
				"noUselessUndefinedInitialization": "error",
				"useDateNow": "error",
				"noExcessiveCognitiveComplexity": {
					"level": "error",
					"options": { "maxAllowedComplexity": 15 }
				}
			},
			"correctness": {
				"noUnusedImports": "error",
				"noUnusedVariables": "error",
				"noUnusedFunctionParameters": "error",
				"useHookAtTopLevel": "error",
				"useExhaustiveDependencies": "warn",
				"noPrivateImports": "error",
				"noUndeclaredDependencies": "error",
				"noNodejsModules": "error"
			},
			"suspicious": {
				"noArrayIndexKey": "error",
				"noExplicitAny": "error",
				"noConsole": {
					"level": "error",
					"options": { "allow": ["error", "warn", "info"] }
				},
				"noEmptyBlockStatements": "error",
				"useAwait": "error",
				"noEvolvingTypes": "error",
				"useErrorMessage": "error",
				"noConstEnum": "error",
				"noMisplacedAssertion": "error",
				"noFocusedTests": "error",
				"noImportCycles": "error",
				"noTsIgnore": "error"
			},
			"style": {
				"useShorthandFunctionType": "off",
				"useImportType": "error",
				"useExportType": "error",
				"noNonNullAssertion": "error",
				"noParameterAssign": "error",
				"useTemplate": "error",
				"useNodejsImportProtocol": "error",
				"useNumberNamespace": "error",
				"noUselessElse": "error",
				"useCollapsedElseIf": "error",
				"useConsistentArrayType": { "level": "error", "options": { "syntax": "shorthand" } },
				"noEnum": "error",
				"useBlockStatements": "error",
				"noNegationElse": "error",
				"useThrowNewError": "error",
				"useThrowOnlyError": "error",
				"noYodaExpression": "error",
				"useConsistentBuiltinInstantiation": "error",
				"useDefaultSwitchClause": "error",
				"useExplicitLengthCheck": "error",
				"useNamingConvention": {
					"level": "error",
					"options": {
						"strictCase": false,
						"requireAscii": true,
						"conventions": [
							{ "selector": { "kind": "objectLiteralProperty" }, "match": ".*" },
							{ "selector": { "kind": "typeProperty" }, "match": ".*" }
						]
					}
				},
				"useNumericSeparators": "error",
				"useShorthandAssign": "error",
				"useExponentiationOperator": "error",
				"noNestedTernary": "error",
				"noProcessEnv": "error",
				"useConsistentArrowReturn": "error"
			},
			"performance": {
				"noAccumulatingSpread": "error",
				"noDelete": "error",
				"useTopLevelRegex": "error",
				"noReExportAll": "error"
			},
			"security": {
				"noBlankTarget": {
					"level": "error",
					"options": {
						"allowNoReferrer": false
					}
				},
				"noDangerouslySetInnerHtml": "error",
				"noDangerouslySetInnerHtmlWithChildren": "error",
				"noGlobalEval": "error",
				"noSecrets": "off"
			},
			"nursery": {
				"noFloatingPromises": "error",
				"noShadow": "error",
				"useExplicitReturnType": "error"
			}
		}
	},
	"overrides": [
		{
			"includes": ["**/*.test.ts", "**/*.test.tsx"],
			"linter": {
				"rules": {
					"performance": { "useTopLevelRegex": "off" },
					"complexity": { "noExcessiveCognitiveComplexity": "off" },
					"suspicious": { "noEmptyBlockStatements": "off" }
				}
			}
		}
	],
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double",
			"semicolons": "always"
		}
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	}
}
