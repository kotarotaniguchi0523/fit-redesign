{
	"$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
	"files": {
		"includes": [
			"app/**",
			"docs/**",
			"!!**/.claude",
			"!!**/.serena",
			"!!**/node_modules",
			"!!**/.git",
			"!!**/.vscode",
			"!!**/.idea",
			"!!**/screenshots",
			"!!**/dist",
			"!!**/dist-ssr"
		]
	},
	"assist": {
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"complexity": {
				"noForEach": "error",
				"noUselessFragments": "error",
				"useOptionalChain": "error",
				"useFlatMap": "error",
				"useSimplifiedLogicExpression": "error"
			},
			"correctness": {
				"noUnusedImports": "error",
				"noUnusedVariables": "error",
				"noUnusedFunctionParameters": "error",
				"useHookAtTopLevel": "error"
			},
			"suspicious": {
				"noArrayIndexKey": "error",
				"noExplicitAny": "error",
				"noConsole": {
					"level": "error",
					"options": { "allow": ["error", "warn", "info"] }
				}
			},
			"style": {
				"useShorthandFunctionType": "off",
				"useImportType": "error",
				"useExportType": "error",
				"noNonNullAssertion": "error",
				"noParameterAssign": "error",
				"useTemplate": "error",
				"useNodejsImportProtocol": "error",
				"useNumberNamespace": "error",
				"noUselessElse": "error",
				"useCollapsedElseIf": "error",
				"useConsistentArrayType": { "level": "error", "options": { "syntax": "shorthand" } }
			},
			"performance": {
				"noAccumulatingSpread": "error",
				"noDelete": "error"
			},
			"security": {
				"noBlankTarget": {
					"level": "error",
					"options": {
						"allowNoReferrer": false
					}
				},
				"noDangerouslySetInnerHtml": "error",
				"noDangerouslySetInnerHtmlWithChildren": "error",
				"noGlobalEval": "error",
				"noSecrets": "off"
			}
		}
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double",
			"semicolons": "always"
		}
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	}
}
