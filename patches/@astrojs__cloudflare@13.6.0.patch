diff --git a/dist/fetch.js b/dist/fetch.js
index 393c1ceb22712f19bfbd3ca0aeb7cd9dae2ec9ea..b248bd34aa364fb2d8e8bb7eb50d318673190db1 100644
--- a/dist/fetch.js
+++ b/dist/fetch.js
@@ -10,9 +10,24 @@ import {
   createLocals,
   getClientAddress
 } from "./utils/cf.js";
-setGetEnv(createGetEnv(globalEnv));
-const app = createApp();
+// [LOCAL PATCH] Lazy init: defer createApp()/setGetEnv() out of module top-level
+// to break the circular dependency with astro/app/entrypoint (fixes "createGetEnv
+// is not a function" during astro build). Upstream: withastro/astro@4bdd240 (未リリース)。
+let app;
+function ensureInitialized() {
+  if (!app) {
+    setGetEnv(createGetEnv(globalEnv));
+    app = createApp();
+  }
+  return app;
+}
 async function cf(state, env, ctx) {
+  const app = ensureInitialized();
+  // [LOCAL PATCH] prerender(build時) は env/ctx が無い。CF 固有セットアップ（session
+  // binding 注入・静的アセット配信・locals）を丸ごとスキップし pages() の描画に委ねる。
+  // 未ガードだと injectSessionBinding(manifest, undefined) が env['SESSION'] で throw し
+  // 全ページ 500("Internal Server Error")化する。
+  if (!env) return void 0;
   injectSessionBinding(app.manifest, env);
   const staticAsset = matchStaticAsset(app.manifest, state.request.url, env);
   if (staticAsset) return staticAsset;
@@ -22,7 +37,10 @@ async function cf(state, env, ctx) {
   }
   Object.assign(state.locals, createLocals(ctx));
   state.clientAddress = getClientAddress(state.request);
-  state.renderOptions.waitUntil = ctx.waitUntil.bind(ctx);
+  // [LOCAL PATCH] prerender 時は ExecutionContext が無いので waitUntil をガード。
+  if (ctx && typeof ctx.waitUntil === "function") {
+    state.renderOptions.waitUntil = ctx.waitUntil.bind(ctx);
+  }
   state.renderOptions.prerenderedErrorPageFetch = createErrorPageFetch(env);
   return void 0;
 }
