{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"strict": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"allowImportingTsExtensions": false,
		"verbatimModuleSyntax": false,
		"jsx": "react-jsx",
		"jsxImportSource": "hono/jsx",
		"types": [
			"@cloudflare/workers-types",
			"vite/client"
		],
		"noEmit": true,
		"lib": [
			"ESNext",
			"DOM",
			"DOM.Iterable"
		]
	},
	"include": [
		"app"
	],
	"exclude": [
		"app/**/*.test.ts",
		"app/**/*.test.tsx",
		"app/types/test/**"
	]
}
